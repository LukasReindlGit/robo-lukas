# Auto-activate this repo's virtualenv when you `cd` here.
# Requires direnv: https://direnv.net — then run once: direnv allow
#
# Windows (Git Bash / MSYS): .venv/Scripts
# Linux / macOS / WSL:        .venv/bin

export VIRTUAL_ENV="${PWD}/.venv"
if [[ -d .venv/Scripts ]]; then
  PATH_add .venv/Scripts
elif [[ -d .venv/bin ]]; then
  PATH_add .venv/bin
fi
