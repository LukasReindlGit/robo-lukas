# Copy to .env and fill in (never commit .env).

# --- Jira (browser session + REST API; no API token required) ---
# Base URL of the Jira instance — change per engagement.
# JIRA_BASE_URL=https://your-org.atlassian.net
# Max issues returned by list commands (default 25)
# JIRA_MAX_RESULTS=25
# Seconds to wait for browser login (default 600)
# JIRA_LOGIN_TIMEOUT=600
# Fine-grained timing (rarely needed)
# JIRA_POST_NAV_SLEEP=0.55
# JIRA_LOGIN_POLL=0.75

# --- Slack (API) ---
# SLACK_BOT_TOKEN=xoxb-...
# Or user token if policy allows — document which you use in modules/slack/README.md

# --- Salesforce ---
# SF_CLI org alias; use `sf org list`
# SF_ORG_ALIAS=my-sandbox

# --- Local git ---
# Single repo (simple case)
# GIT_REPO_PATH=C:\Users\You\Projects\my-sfdc-repo
# Multiple repos for all-summary (comma-separated)
# GIT_REPO_PATHS=C:\Projects\repo-a,C:\Projects\repo-b
# Default base ref for diff/log/summary (default: main)
# GIT_BASE_REF=main
# Default commit count for log/summary (default: 15)
# GIT_LOG_LIMIT=15

# --- Browser / Microsoft (no Graph; profile + URLs) ---
# If IT blocks chromedriver downloads/execution, see modules/outlook/README.md
# “Corporate IT restrictions” — you may need Graph/Power Automate or a dev VM instead.
# Path to a dedicated Chrome user-data dir (persistent SSO). Do NOT use your main daily profile.
# M365_BROWSER_USER_DATA_DIR=/absolute/path/to/robo-lukas-chrome-profile
# When using Windows Chrome from WSL, optional raw Windows path for --user-data-dir:
# M365_BROWSER_USER_DATA_DIR_WINDOWS=C:\Users\You\AppData\Local\robo-lukas-chrome
# Optional: profile folder name inside user-data-dir (default: Default)
# CHROME_PROFILE_DIRECTORY=Default
# Linux Chromium/Chrome (inside WSL):
# CHROME_BINARY=/usr/bin/chromium-browser
# Windows Chrome from WSL — prefer remote ChromeDriver (scripts/chromedriver-for-wsl.ps1).
# ChromeDriver.exe: %LOCALAPPDATA%\robo-lukas\chromedriver-win64\chromedriver.exe (recommended)
# WSL path (for auto-start with: python -m robo_lukas.outlook with-bridge …)
# CHROMEDRIVER_WINDOWS_EXE=/mnt/c/Users/You/AppData/Local/robo-lukas/chromedriver-win64/chromedriver.exe
# Optional if you start ChromeDriver manually (PowerShell script):
# CHROMEDRIVER_REMOTE_URL=http://10.255.255.254:9515
# CHROME_BINARY=/mnt/c/Program Files/Google/Chrome/Application/chrome.exe
# ROBO_OUTLOOK_USE_WINDOWS_CHROME=1
# Legacy (often broken from WSL): CHROMEDRIVER_PATH=/mnt/c/tools/chromedriver.exe
# Outlook web base (org-dependent)
# OUTLOOK_WEB_URL=https://outlook.office.com/mail/
# Selenium: max seconds to wait for list / reading pane
# OUTLOOK_EXPLICIT_WAIT=25
# Pause after navigation (default 0.55; raise for slow tenants)
# OUTLOOK_POST_NAV_SLEEP=0.55
# SSO poll interval while waiting for /mail/ (default 0.75)
# OUTLOOK_LOGIN_POLL=0.75
# List row poll / scroll / search result pauses (defaults ~0.12 / 0.22 / 0.35)
# OUTLOOK_LIST_ROW_POLL=0.12
# OUTLOOK_SCROLL_KEY_SLEEP=0.22
# OUTLOOK_SEARCH_EXTRA_SLEEP=0.35
# driver.implicitly_wait seconds (default 1)
# OUTLOOK_IMPLICIT_WAIT=1
# WSL/Linux: force GPU-safe Chrome flags (auto-on under WSL)
# ROBO_OUTLOOK_WSL_FLAGS=1
# ChromeDriver log for debugging SessionNotCreatedException
# ROBO_OUTLOOK_CHROMEDRIVER_LOG=/tmp/chromedriver.log
# Extra Chrome CLI args (space-separated, each --foo)
# OUTLOOK_CHROME_EXTRA_ARGS=--disable-features=Translate
# Microsoft login helper (Outlook + To Do): substring to pick the right tile on “Pick an account”.
# MICROSOFT_ACCOUNT_HINT=user@company.com
# (alias) M365_ACCOUNT_TILE_SUBSTRING=user@company.com

# Microsoft To Do (browser module robo-todo; same Chrome profile as Outlook is fine)
# Default entry URL is https://to-do.office.com/tasks/inbox (Tasks on commercial host).
# Personal Microsoft account: often MS_TODO_WEB_URL=https://to-do.live.com/tasks/
# MS_TODO_WEB_URL=https://to-do.office.com/tasks/inbox
# Waits / first paint
# MS_TODO_EXPLICIT_WAIT=8
# MS_TODO_POST_NAV_SLEEP=0.22
# MS_TODO_SHELL_SETTLE=0.45
# MS_TODO_SHELL_POLL=0.32
# Max seconds per wait-login loop polling the task shell (default 9)
# MS_TODO_SHELL_BURST=9
# Hard max seconds on one task page for list UI (then TimeoutError; default 4)
# MS_TODO_PAGE_WAIT_MAX=4
# Timings fall back to OUTLOOK_* where noted: MS_TODO_LOGIN_POLL, MS_TODO_LIST_ROW_POLL,
# MS_TODO_SCROLL_KEY_SLEEP, MS_TODO_IMPLICIT_WAIT
